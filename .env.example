# FinSolve AI Assistant - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# GROQ API (Free LLM Inference)
# ===========================================
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ===========================================
# LangSmith (Optional - Free Monitoring)
# ===========================================
# Get your API key from: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=finsolve-ai-assistant

# ===========================================
# Application Settings
# ===========================================
# Environment: development, staging, production
ENVIRONMENT=development

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Rate Limiting (requests per user per day)
MAX_REQUESTS_PER_USER_PER_DAY=100

# ===========================================
# Model Configuration
# ===========================================
# Groq Models (Free): llama-3.3-70b-versatile, llama-3.1-8b-instant
LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ===========================================
# Vector Store Settings
# ===========================================
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ===========================================
# AWS Settings (For Deployment)
# ===========================================
AWS_REGION=us-east-1
# AWS credentials are typically set via AWS CLI or IAM roles
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
